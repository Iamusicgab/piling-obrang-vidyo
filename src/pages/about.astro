	},
	{
		role: "Head Secretariats",
		members: [
			{ name: "Giancarlo Santiago", img: "/bg.png" },
			{ name: "Maxine Mangaoang", img: "/bg.png" },
		],
	},
	{
		role: "Marketing Heads",
		members: [
			{ name: "Ralf Montes", img: "/img/team/ralfmontes.png" },
			{ name: "Eia Arcenal", img: "/img/team/eiaarcenal.png" },
		],
	},
	{
		role: "Logistics Heads",
		members: [
			{ name: "Kio Magno", img: "/bg.png" },
			{ name: "Hannah Saludades", img: "/img/team/saludades.png" },
		],
	},
	{
		role: "Programs Heads",
		members: [
			{ name: "Seven Fangki", img: "/bg.png" },
			{ name: "Dustin Laguna", img: "/bg.png" },
		],
	},
	{
		role: "Selection Heads",
		members: [
			{ name: "Julia Francine Malanos", img: "/img/team/malanos.png" },
			{ name: "Josiah Tollison", img: "/img/team/tollison.png" },
		],
	},
	{
		role: "Operations Head",
		members: [{ name: "Gabriel Gonzales", img: "/bg.png" }],
	},
	{
		role: "Creatives Heads",
		members: [
			{ name: "Cyrene Navalta", img: "/img/team/navalta.png" },
			{ name: "Adrian Malasig", img: "/img/team/malasig.png" },
		],
	},
	{
		role: "Promotions Heads",
		members: [
			{ name: "Josef Earl Lalo", img: "/img/team/jourches.png" },
			{ name: "Juliane Delleopac", img: "/bg.png" },
