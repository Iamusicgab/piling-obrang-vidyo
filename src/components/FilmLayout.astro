---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const { frontmatter } = Astro.props;

// --- 1. Trailer (YouTube or Facebook) Transformation ---
let embedUrl = frontmatter.trailer_url ?? "";

if (embedUrl) {
	try {
		const normalized = embedUrl.trim();
		// YouTube handling
		if (normalized.includes("youtube.com") || normalized.includes("youtu.be")) {
			if (normalized.includes("watch?v=")) {
				const urlObj = new URL(normalized);
				const videoId = urlObj.searchParams.get("v");
				embedUrl = `https://www.youtube.com/embed/${videoId}`;
			} else if (normalized.includes("youtu.be/")) {
				const urlObj = new URL(normalized);
				const videoId = urlObj.pathname.substring(1);
				embedUrl = `https://www.youtube.com/embed/${videoId}`;
			}
			// Facebook handling
		} else if (
			normalized.includes("facebook.com") ||
			normalized.includes("fb.watch")
		) {
			let videoHref = normalized;
			if (!videoHref.startsWith("http")) videoHref = "https://" + videoHref;
			embedUrl = `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(videoHref)}&show_text=false&width=560`;
		}
	} catch (err) {
		// parsing failed -> leave embedUrl as provided
	}
}

// --- 2. Google Drive Stills Transformation ---
const transformDriveLink = (url: string) => {
	if (!url) return url;

	// Looks for either "/d/" OR "id=" and grabs the alphanumeric ID
	const match = url.match(/(?:\/d\/|id=)([a-zA-Z0-9_-]+)/);

	if (match && match[1]) {
		// Look at our local public folder!
		return `/img/${match[1]}.jpg`;
	}

	return url;
};

// Transform the stills and BTS arrays
const formattedStills = frontmatter.stills
	? frontmatter.stills.map(transformDriveLink)
	: [];

const formattedBts = frontmatter.bts
	? frontmatter.bts.map(transformDriveLink)
	: [];

// Transform poster image
const posterImage = transformDriveLink(frontmatter.poster_image);

// --- 3. Filmmaker Photos Normalization ---
// Get the raw photo field (could be undefined, a string, or an array)
const rawFilmmakerPhoto = frontmatter.filmmaker?.photo;

// Normalize to an array, transform links, and filter out empty strings
const filmmakerPhotos = (
	Array.isArray(rawFilmmakerPhoto)
		? rawFilmmakerPhoto
		: rawFilmmakerPhoto
			? [rawFilmmakerPhoto]
			: []
)
	.map(transformDriveLink)
	.filter((url) => url !== "");
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{frontmatter.title} | Piling Obrang Vidyo</title>
	</head>
	<body class="bg-black text-white font-stack max-w-360 mx-auto">
		<Navbar />

		<div class="m-6 flex flex-col gap-8">
			<iframe
				class="w-full aspect-video rounded-lg max-w-4xl mx-auto"
				src={embedUrl}
				title="Trailer"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				referrerpolicy="strict-origin-when-cross-origin"
				allowfullscreen></iframe>

			<div class="flex gap-4 mx-auto flex-col md:flex-row">
				<img
					src={posterImage}
					class="rounded-lg max-w-72 mx-auto object-cover aspect-[9/14]"
					alt={`${frontmatter.title} Poster`}
				/>
				<div class="flex flex-col gap-4">
					<div>
						<p class="text-2xl">{frontmatter.title}</p>
						<p>
							by {frontmatter.director} | {frontmatter.school}
						</p>
					</div>
					{
						frontmatter.award && (
							<p class="text-yellow font-bold">{frontmatter.award}</p>
						)
					}
					<p>
						{frontmatter.runtime} | {frontmatter.genre}
					</p>
					<p>
						<b>Logline:</b>
						{frontmatter.logline}
					</p>
					<p>
						<b>Synopsis:</b>
						{frontmatter.synopsis}
					</p>
				</div>
			</div>

			<div class="flex flex-col gap-4">
				<h1 class="text-2xl">Stills</h1>
				<div
					class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 gap-3 w-full max-w-4xl"
				>
					{
						formattedStills.map((stillUrl: string) => (
							<img
								src={stillUrl}
								class="rounded-lg w-full flex-1 md:max-w-72 h-auto object-cover aspect-video"
								alt={`Still from ${frontmatter.title}`}
								loading="lazy"
							/>
						))
					}
				</div>
			</div>

			<div class="flex flex-col gap-4">
				<h1 class="text-2xl">Behind the Scenes</h1>
				<div
					class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 gap-3 w-full max-w-4xl"
				>
					{
						formattedBts.map((btsUrl: string) => (
							<img
								src={btsUrl}
								class="rounded-lg w-full h-auto object-cover aspect-video"
								alt={`Behind the scenes from ${frontmatter.title}`}
								loading="lazy"
							/>
						))
					}
				</div>
			</div>

			<div class="flex flex-col gap-4">
				<h1 class="text-2xl">Filmmaker's Profile</h1>
				<div
					class="flex flex-col md:flex-row gap-4 items-center md:items-start"
				>
					{/* Render photos if available, otherwise show fallback */}
					<div
						class="flex flex-col flex-wrap justify-center md:justify-start gap-3"
					>
						{
							filmmakerPhotos.length > 0 ? (
								filmmakerPhotos.map((photoUrl: string) => (
									<img
										src={photoUrl}
										class="rounded-lg w-full max-w-72 object-cover aspect-square"
										alt={`Photo of ${frontmatter.filmmaker.name}`}
									/>
								))
							) : (
								<img
									src="/img/noimage.jpg"
									class="rounded-lg w-full max-w-72 object-cover aspect-square"
									alt={`Photo of ${frontmatter.filmmaker.name}`}
								/>
							)
						}
					</div>
					<div class="flex flex-col gap-3 flex-1">
						<p class="text-2xl">{frontmatter.filmmaker.name}</p>
						<p>
							{frontmatter.filmmaker.bio}
						</p>
					</div>
				</div>
			</div>
			<div class="flex flex-col gap-4">
				<h1 class="text-2xl">Crew</h1>
				<p class="whitespace-pre-wrap">
					{frontmatter.crew}
				</p>
			</div>
			<Footer />
		</div>
	</body>
</html>
