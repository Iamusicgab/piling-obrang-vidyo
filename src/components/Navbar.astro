---

---

<nav
	class="sticky top-0 w-full flex md:flex-col md:justify-center justify-between md:items-center p-4 text-white backdrop-blur-sm border-b border-white/20 z-40"
>
	<a href="/"><img src="/povwhite.png" class="w-18" /></a>
	<button
		id="mobile-toggle"
		class="w-10 md:hidden"
		aria-label="Toggle menu"
		aria-expanded="false"
	>
		<img src="/sandwich.svg" alt="menu" />
	</button>
	<ul id="nav-menu" class="hidden md:flex justify-center items-center gap-6">
		<li class="hover:underline"><a href="/about">About</a></li>
		<li class="relative group">
			<a
				href="#"
				id="festival-btn-desktop"
				class="hover:underline inline-flex items-center festival-toggle"
				aria-haspopup="true"
				aria-expanded="false"
				aria-controls="festival-submenu-desktop"
			>
				Festival
				<svg
					class="ml-1 w-3 h-3"
					viewBox="0 0 20 20"
					fill="currentColor"
					aria-hidden="true"
					><path
						d="M5.23 7.21a.75.75 0 011.06.02L10 11.293l3.71-4.06a.75.75 0 111.08 1.04l-4.25 4.656a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
					></path></svg
				>
			</a>
			<ul
				id="festival-submenu-desktop"
				class="absolute left-0 mt-2 w-40 bg-black/90 border border-white/10 rounded shadow-lg opacity-0 translate-y-1 pointer-events-none transition-all duration-250 delay-150 z-50"
			>
				<li class="px-3 py-2 hover:bg-white/5">
					<a href="/pov21">POV 21</a>
				</li>
				<li class="px-3 py-2 hover:bg-white/5">
					<a href="/pov20">POV 20</a>
				</li>
			</ul>
		</li>
		<li class="hover:underline"><a href="/submit">POV 22</a></li>
		<li class="hover:underline">
			<a href="/pelikolektibo">Pelikolektibo</a>
		</li>
		<li
			class="bg-red p-2 rounded-sm transition hover:bg-white hover:text-black active:bg-black active:text-white"
		>
			<a href="/submit">Submissions</a>
		</li>
	</ul>
</nav>

<!-- Full-screen mobile menu (hidden by default) -->
<div id="mobile-menu" class="hidden fixed inset-0 z-50 bg-black/95 text-white">
	<nav class="w-full h-full p-12 bg-black text-3xl relative">
		<button
			id="mobile-close"
			type="button"
			class="absolute top-6 right-6 text-white p-2 rounded"
			onclick="(function(){document.getElementById('mobile-menu').classList.add('hidden');document.body.classList.remove('overflow-hidden');const b=document.getElementById('mobile-toggle'); if(b) b.setAttribute('aria-expanded','false');})();"
			>✕</button
		>
		<ul class="grid gap-4 align-middle">
			<li class="">
				<a href="/" class="block border-b-4 border-white">Home</a>
			</li>
			<li class="">
				<a href="/about" class="block border-b-4 border-white">About</a>
			</li>
			<li class="border-b-4 border-white">
				<button id="mobile-festival-btn" class="w-full flex items-center py-2">
					<span>Festival</span>
					<svg class="ml-2 w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
						><path
							d="M5.23 7.21a.75.75 0 011.06.02L10 11.293l3.71-4.06a.75.75 0 111.08 1.04l-4.25 4.656a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
						></path></svg
					>
				</button>
				<ul id="mobile-festival-sub" class="hidden flex-col mt-2 pl-4">
					<li class="py-2">
						<a href="/pov21" class="block">POV 21</a>
					</li>
					<li class="py-2">
						<a href="/pov20" class="block">POV 20</a>
					</li>
				</ul>
			</li>
			<li class="border-b-4 border-white">
				<a href="/submit" class="block">POV 22</a>
			</li>
			<li class="border-b-4 border-white">
				<a href="/pelikolektibo" class="block">Pelikolektibo</a>
			</li>
			<li>
				<a href="/submit" class="bg-red inline-block px-4 py-2 rounded-sm"
					>Submissions</a
				>
			</li>
		</ul>
	</nav>
</div>

<script>
	(function () {
		const btn = document.getElementById("mobile-toggle");
		const mobileMenu = document.getElementById("mobile-menu");
		if (!btn || !mobileMenu) return;

		btn.addEventListener("click", () => {
			const expanded = btn.getAttribute("aria-expanded") === "true";
			btn.setAttribute("aria-expanded", String(!expanded));
			mobileMenu.classList.toggle("hidden");
			// prevent background scroll when open
			document.body.classList.toggle("overflow-hidden");
		});

		// Festival submenu inside mobile menu
		const festBtn = document.getElementById("mobile-festival-btn");
		const festSub = document.getElementById("mobile-festival-sub");
		if (festBtn && festSub) {
			festBtn.addEventListener("click", () => {
				const isHidden = festSub.classList.contains("hidden");
				festSub.classList.toggle("hidden", !isHidden);
			});
		}

		// mobile close button inside overlay
		const mobileCloseBtn = document.getElementById("mobile-close");
		if (mobileCloseBtn) {
			mobileCloseBtn.addEventListener("click", () => {
				mobileMenu.classList.add("hidden");
				document.body.classList.remove("overflow-hidden");
				btn.setAttribute("aria-expanded", "false");
			});
		}

		// Desktop festival submenu: toggle on click, close on outside click or Escape
		const festBtnDesktop = document.getElementById("festival-btn-desktop");
		const festSubDesktop = document.getElementById("festival-submenu-desktop");
		if (festBtnDesktop && festSubDesktop) {
			const openDesktopSub = () => {
				festSubDesktop.classList.remove(
					"opacity-0",
					"translate-y-1",
					"pointer-events-none",
				);
				festSubDesktop.classList.add(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				festBtnDesktop.setAttribute("aria-expanded", "true");
			};
			const closeDesktopSub = () => {
				festSubDesktop.classList.add(
					"opacity-0",
					"translate-y-1",
					"pointer-events-none",
				);
				festSubDesktop.classList.remove(
					"opacity-100",
					"translate-y-0",
					"pointer-events-auto",
				);
				festBtnDesktop.setAttribute("aria-expanded", "false");
			};

			festBtnDesktop.addEventListener("click", (e) => {
				// only override default navigation on desktop widths
				if (window.innerWidth >= 768) {
					e.preventDefault();
					const expanded =
						festBtnDesktop.getAttribute("aria-expanded") === "true";
					if (expanded) closeDesktopSub();
					else openDesktopSub();
				}
			});

			// close submenu when clicking outside
			document.addEventListener("click", (e) => {
				const target = e.target;
				if (!(target instanceof Node)) return;
				if (
					!festBtnDesktop.contains(target) &&
					!festSubDesktop.contains(target)
				) {
					closeDesktopSub();
				}
			});

			// close on Escape
			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") {
					closeDesktopSub();
				}
			});
		}
	})();
</script>

<script>
	// Delegated fallback: ensure any click on the mobile close button hides the overlay
	document.addEventListener("click", function (e) {
		const target = e.target;
		if (!(target instanceof Element)) return;
		const closeBtn =
			target.id === "mobile-close" ? target : target.closest("#mobile-close");
		if (closeBtn) {
			const mobileMenu = document.getElementById("mobile-menu");
			if (mobileMenu) {
				mobileMenu.classList.add("hidden");
				document.body.classList.remove("overflow-hidden");
				const toggle = document.getElementById("mobile-toggle");
				if (toggle) toggle.setAttribute("aria-expanded", "false");
			}
		}
	});
</script>
