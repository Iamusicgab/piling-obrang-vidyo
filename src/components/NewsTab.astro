---
const { text, link, image, date } = Astro.props;
---

<a href={link} class="group">
	<div
		class="bg-cover bg-center rounded-lg w-full flex justify-end gap-2 box-border p-3 relative h-full aspect-video"
		style={`background-image: url('${image}'); background-size: 115%;`}
	>
		<div class="w-full flex flex-col justify-end z-10">
			<h2
				class="text-lg md:text-base text-white w-full line-clamp-2 group-hover:text-white text-shadow-lg"
			>
				{text}
			</h2>
			<p
				class="text-white group-hover:text-white text-shadow-lg text-xs md:text-sm"
			>
				{date}
			</p>
			<slot />
		</div>
		<div
			class="relative flex flex-col justify-end transition group-hover:translate-x-4 group-hover:translate-y-4 z-10"
		>
			<!-- <img
				src="/arrowdown.svg"
				class="w-12 group-hover:white"
				alt="Arrow pointing down and to the right"
			/> -->
			<svg
				class="w-8 stroke-white"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path
					d="M7 7L17 17M17 17V7M17 17H7"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"></path>
			</svg>
		</div>
		<div
			class="transition absolute inset-0 z-0 rounded-lg pointer-events-none group-hover:bg-maroon/90"
		>
			<div
				class="transition absolute inset-0 z-0 bg-linear-to-t from-maroon group-hover:from-maroon rounded-lg pointer-events-none"
			>
			</div>
		</div>
	</div>
</a>
