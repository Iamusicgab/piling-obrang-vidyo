---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Loading from "../components/Loading.astro";

interface Props {
	title?: string;
}

const { title = "Piling Obrang Vidyo" } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/povwhite.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-black text-white font-stack max-w-360 mx-auto">
		<Loading />
		<Navbar />
		<slot />
		<Footer />
	</body>
</html>
